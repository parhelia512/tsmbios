<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <ProjectGuid>{EFEFD773-6578-4B28-AFB6-3DDA2C415F28}</ProjectGuid>
        <ProjectVersion>20.3</ProjectVersion>
        <FrameworkType>None</FrameworkType>
        <AppType>Console</AppType>
        <Base>True</Base>
        <Config Condition="'$(Config)'==''">Debug</Config>
        <Platform Condition="'$(Platform)'==''">Win32</Platform>
        <TargetedPlatforms>1</TargetedPlatforms>
        <CC_Suffix Condition="'$(CC_Suffix)'==''">c</CC_Suffix>
        <ProjectName Condition="'$(ProjectName)'==''">OutOfBandRemoteAccessInfo</ProjectName>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Base' or '$(Base)'!=''">
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win64x' and '$(Base)'=='true') or '$(Base_Win64x)'!=''">
        <Base_Win64x>true</Base_Win64x>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Debug' or '$(Cfg_1)'!=''">
        <Cfg_1>true</Cfg_1>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win32' and '$(Cfg_1)'=='true') or '$(Cfg_1_Win32)'!=''">
        <Cfg_1_Win32>true</Cfg_1_Win32>
        <CfgParent>Cfg_1</CfgParent>
        <Cfg_1>true</Cfg_1>
        <Base>true</Base>
        <PlatformSDK/>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Release' or '$(Cfg_2)'!=''">
        <Cfg_2>true</Cfg_2>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win32' and '$(Cfg_2)'=='true') or '$(Cfg_2_Win32)'!=''">
        <Cfg_2_Win32>true</Cfg_2_Win32>
        <CfgParent>Cfg_2</CfgParent>
        <Cfg_2>true</Cfg_2>
        <Base>true</Base>
        <PlatformSDK/>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base)'!=''">
        <DCC_CBuilderOutput>JPHNE</DCC_CBuilderOutput>
        <DynamicRTL>true</DynamicRTL>
        <UsePackages>true</UsePackages>
        <Multithreaded>true</Multithreaded>
        <IntermediateOutputDir>.\$(Platform)\$(Config)</IntermediateOutputDir>
        <FinalOutputDir>.\$(Platform)\$(Config)</FinalOutputDir>
        <ProjectType>CppConsoleApplication</ProjectType>
        <SanitizedProjectName>OutOfBandRemoteAccessInfo</SanitizedProjectName>
        <AllPackageLibs>rtl.lib</AllPackageLibs>
        <DCC_Define>DISABLEWMI;$(DCC_Define)</DCC_Define>
        <DCC_UsePackage>rtl;$(DCC_UsePackage)</DCC_UsePackage>
        <DCC_Namespace>System;System.Win;Winapi;$(DCC_Namespace)</DCC_Namespace>
        <TSMBIOS_CBUILDER_SDK_INCLUDE Condition="'$(TSMBIOS_CBUILDER_SDK_INCLUDE)'=='' And Exists('$(BDS)\include\windows\sdk\windows.h')">$(BDS)\include\windows\sdk</TSMBIOS_CBUILDER_SDK_INCLUDE>
        <IncludePath>..\..\source\;..\..\source;$(TSMBIOS_CBUILDER_SDK_INCLUDE);$(BDSINCLUDE)\windows\vcl;$(BDSINCLUDE)\windows\rtl;$(BDSINCLUDE)\windows\crtl;$(BDSINCLUDE)\windows\rtl\sys;$(IncludePath)</IncludePath>
        <ILINK_LibraryPath>..\..\source\;..\..\source;$(BDSLIB)\$(PLATFORM)c\release;$(BDSLIB)\$(PLATFORM)\release;$(ILINK_LibraryPath)</ILINK_LibraryPath>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base_Win64x)'!=''">
        <BCC_EnableBatchCompilation>true</BCC_EnableBatchCompilation>
        <UsePackages>false</UsePackages>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_1)'!=''">
        <Defines>_DEBUG;$(Defines)</Defines>
        <BCC_DebugLineNumbers>true</BCC_DebugLineNumbers>
        <BCC_SourceDebuggingOn>true</BCC_SourceDebuggingOn>
        <BCC_EnableCPPExceptions>true</BCC_EnableCPPExceptions>
        <ILINK_FullDebugInfo>true</ILINK_FullDebugInfo>
        <ILINK_LibraryPath>$(BDSLIB)\$(PLATFORM)c\debug;$(BDSLIB)\$(PLATFORM)\debug;$(ILINK_LibraryPath)</ILINK_LibraryPath>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_1_Win32)'!=''">
        <BCC_UseClassicCompiler>false</BCC_UseClassicCompiler>
        <LinkPackageImports>rtl.bpi</LinkPackageImports>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_2)'!=''">
        <Defines>NDEBUG;$(Defines)</Defines>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_2_Win32)'!=''">
        <BCC_UseClassicCompiler>false</BCC_UseClassicCompiler>
        <LinkPackageImports>rtl.bpi</LinkPackageImports>
    </PropertyGroup>
    <ItemGroup>
        <CppCompile Include="OutOfBandRemoteAccessInfo.cpp">
            <BuildOrder>0</BuildOrder>
        </CppCompile>
        <ResourceCompile Include="OutOfBandRemoteAccessInfo.rc">
            <BuildOrder>1</BuildOrder>
        </ResourceCompile>
        <PackageImport Include="rtl.bpi">
            <BuildOrder>3</BuildOrder>
        </PackageImport>
        <DelphiCompile Include="..\..\source\uSMBIOS.pas">
            <BuildOrder>2</BuildOrder>
        </DelphiCompile>
        <BuildConfiguration Include="Base">
            <Key>Base</Key>
        </BuildConfiguration>
        <BuildConfiguration Include="Debug">
            <Key>Cfg_1</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
        <BuildConfiguration Include="Release">
            <Key>Cfg_2</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
    </ItemGroup>
    <ProjectExtensions>
        <Borland.Personality>CPlusPlusBuilder.Personality.12</Borland.Personality>
        <Borland.ProjectType>CppConsoleApplication</Borland.ProjectType>
        <BorlandProject>
            <CPlusPlusBuilder.Personality>
                <Source>
                    <Source Name="MainSource">OutOfBandRemoteAccessInfo.cpp</Source>
                </Source>
                <ProjectProperties>
                    <ProjectProperties Name="AutoShowDeps">False</ProjectProperties>
                    <ProjectProperties Name="ManagePaths">True</ProjectProperties>
                    <ProjectProperties Name="VerifyPackages">True</ProjectProperties>
                    <ProjectProperties Name="IndexFiles">False</ProjectProperties>
                </ProjectProperties>
            </CPlusPlusBuilder.Personality>
            <Platforms>
                <Platform value="Win32">True</Platform>
                <Platform value="Win64">False</Platform>
                <Platform value="Win64x">False</Platform>
            </Platforms>
        </BorlandProject>
        <ProjectFileVersion>12</ProjectFileVersion>
    </ProjectExtensions>
    <Import Project="$(BDS)\Bin\CodeGear.Cpp.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Cpp.Targets')"/>
    <Import Project="$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj" Condition="Exists('$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj')"/>
</Project>
